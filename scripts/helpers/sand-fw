#!/usr/bin/env bash
# sand-fw — privileged firewall helper for the Roku-E8C3 dashboard.
#
# Rebuilds the nftables ruleset (base policy + per-device routing rules) from
# the database. sudo-invoked by the `sand` user under a scoped NOPASSWD rule.
set -euo pipefail

SAND_HOME="${SAND_HOME:-/opt/sandos}"

action="${1:-apply}"
case "$action" in
  apply)
    cd "${SAND_HOME}/backend"
    exec "${SAND_HOME}/venv/bin/python" -m app.netapply firewall
    ;;
  *)
    echo "usage: sand-fw apply" >&2
    exit 2
    ;;
esac
