#!/usr/bin/env bash
# roku-net — privileged networking helper for the Roku-E8C3 dashboard.
#
# sudo-invoked by the unprivileged `roku` user under a scoped NOPASSWD rule.
# It only dispatches to the netapply tool / systemctl with a fixed verb set;
# no caller argument reaches a shell.
set -euo pipefail

ROKU_HOME="${ROKU_HOME:-/opt/roku-gateway}"
PYTHON="${ROKU_HOME}/venv/bin/python"
BACKEND="${ROKU_HOME}/backend"

action="${1:-}"
case "$action" in
  apply|firewall|status)
    cd "$BACKEND"
    exec "$PYTHON" -m app.netapply "$action"
    ;;
  restart-ap)
    systemctl restart hostapd dnsmasq
    echo "access point services restarted"
    ;;
  *)
    echo "usage: roku-net {apply|firewall|status|restart-ap}" >&2
    exit 2
    ;;
esac
