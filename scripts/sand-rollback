#!/usr/bin/env bash
# sand-rollback — restore the pre-cutover network configuration.
#
# Run automatically by the auto-rollback guard if a cutover is not confirmed,
# and available to the operator as a manual escape hatch:
#
#   sudo sand-rollback          restore previous networking and reboot
#
# It reverses sand-apply: the access-point services are stopped, the
# NetworkManager override is removed, and the snapshot of /etc/netplan and the
# saved NetworkManager connections is restored. The device then reboots so it
# comes back on its original network.
set -euo pipefail

SNAP_DIR="/var/lib/sandos/cutover-snapshot"
MODE="${1:-manual}"

[ "$(id -u)" -eq 0 ] || { echo "sand-rollback: must run as root" >&2; exit 1; }

logger -t sand-rollback "restoring pre-cutover networking (mode=${MODE})"
echo "sand-rollback: restoring previous network configuration..."

# Stop the access point and dashboard.
systemctl stop hostapd dnsmasq sand-dashboard 2>/dev/null || true

# Remove the NetworkManager override so the radio is managed again.
rm -f /etc/NetworkManager/conf.d/00-sand-unmanaged.conf

# Restore the netplan and NetworkManager connection snapshot.
if [ -d "$SNAP_DIR/netplan" ]; then
    rm -f /etc/netplan/*.yaml /etc/netplan/*.yml 2>/dev/null || true
    cp -a "$SNAP_DIR/netplan/." /etc/netplan/ 2>/dev/null || true
fi
if [ -d "$SNAP_DIR/nm" ]; then
    cp -a "$SNAP_DIR/nm/." /etc/NetworkManager/system-connections/ 2>/dev/null || true
    chmod 600 /etc/NetworkManager/system-connections/* 2>/dev/null || true
fi

# Do not re-cut-over on the next boot.
systemctl disable sand-netapply 2>/dev/null || true
rm -f /run/sand-cutover-pending

logger -t sand-rollback "networking restored — rebooting"
echo "sand-rollback: previous networking restored. Rebooting now."
sync
systemctl reboot
