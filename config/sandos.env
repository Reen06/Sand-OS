# Roku-E8C3 dashboard service environment.
# Installed to /etc/sandos/sandos.env and read by the systemd unit.

SAND_HOME=/opt/sandos
SAND_DB=/var/lib/sandos/sand.db
SAND_CONFIG_DIR=/etc/sandos
SAND_LOG_DIR=/var/log/sandos
SAND_BACKUP_DIR=/var/lib/sandos/backups
SAND_FRONTEND_DIR=/opt/sandos/frontend
SAND_HELPER_DIR=/usr/local/lib/sandos

# Dashboard bind address. The backend binds all interfaces; access is
# restricted to the AP/LAN side by the nftables ruleset (the dashboard is
# never reachable from the upstream link).
SAND_BIND_HOST=0.0.0.0
SAND_BIND_PORT=80

# Network identity (device cover name — do not change without reason).
SAND_HOSTNAME=Roku-E8C3
SAND_AP_SSID=Roku-E8C3
SAND_LAN_CIDR=10.0.0.1/24
SAND_GUEST_CIDR=10.0.1.1/24
