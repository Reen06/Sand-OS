# Roku-E8C3 dashboard service environment.
# Installed to /etc/roku-gateway/roku-gateway.env and read by the systemd unit.

ROKU_HOME=/opt/roku-gateway
ROKU_DB=/var/lib/roku-gateway/roku.db
ROKU_CONFIG_DIR=/etc/roku-gateway
ROKU_LOG_DIR=/var/log/roku-gateway
ROKU_BACKUP_DIR=/var/lib/roku-gateway/backups
ROKU_FRONTEND_DIR=/opt/roku-gateway/frontend
ROKU_HELPER_DIR=/usr/local/lib/roku-gateway

# Dashboard bind address. The backend binds all interfaces; access is
# restricted to the AP/LAN side by the nftables ruleset (the dashboard is
# never reachable from the upstream link).
ROKU_BIND_HOST=0.0.0.0
ROKU_BIND_PORT=80

# Network identity.
ROKU_HOSTNAME=Roku-E8C3
ROKU_AP_SSID=Roku-E8C3
ROKU_LAN_CIDR=10.0.0.1/24
ROKU_GUEST_CIDR=10.0.1.1/24
