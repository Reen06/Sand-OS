#!/usr/sbin/nft -f
# Roku-E8C3 — base firewall (template).
#
# A dedicated `inet sand` table so it never collides with Docker or other
# nftables users. sand-fw substitutes the placeholders, appends per-device
# routing/kill-switch rules from the database, and loads the result.
#
# Security model:
#   - The dashboard (port 80/443) and SSH are reachable ONLY from the AP/LAN
#     side, never from the upstream interface.
#   - Guest subnet is isolated from the main LAN.
#   - NAT masquerades LAN/guest traffic out the upstream interface.

# netdev ingress hook runs before the inet layer strips the link header,
# so ether saddr is reliably accessible here. MAC→fwmark rules live here.
table netdev sand
delete table netdev sand

table netdev sand {
    chain ap_ingress {
        type filter hook ingress device "{{AP_IFACE}}" priority 0;
        # ROKU-NETDEV-RULES
    }
}

table inet sand
delete table inet sand

table inet sand {
    # prerouting chain kept for any future inet-level rules.
    chain prerouting {
        type filter hook prerouting priority mangle; policy accept;
    }

    chain input {
        type filter hook input priority 0; policy drop;

        iif "lo" accept
        ct state established,related accept
        ct state invalid drop
        meta l4proto { icmp, icmpv6 } accept

        # From the AP / LAN side only:
        iifname "{{AP_IFACE}}" udp dport { 67, 68 } accept     comment "DHCP"
        iifname "{{AP_IFACE}}" meta l4proto { tcp, udp } th dport 53 accept  comment "DNS"
        iifname "{{AP_IFACE}}" tcp dport { 80, 443 } accept    comment "dashboard"
        iifname "{{AP_IFACE}}" tcp dport 8421 accept           comment "pisugar"
        iifname "{{AP_IFACE}}" tcp dport 22 accept             comment "ssh (recovery)"

        # WireGuard listen ports (tunnels terminate locally).
        udp dport 51820-51829 accept                           comment "wireguard"

        # Anything else — including all traffic from the upstream link —
        # is dropped by the default policy.
    }

    chain forward {
        type filter hook forward priority 0; policy drop;

        ct state invalid drop

        # Per-device blocked/kill-switch drops BEFORE ct accept so that blocking
        # a device also kills its existing established connections immediately.
        # ROKU-DEVICE-RULES

        ct state established,related accept

        # Guest isolation — guest subnet cannot reach the main LAN.
        ip saddr {{GUEST_NET}} ip daddr {{LAN_NET}} drop
        ip saddr {{LAN_NET}} ip daddr {{GUEST_NET}} drop

        # LAN and guest may reach the internet via the upstream interface.
        iifname "{{AP_IFACE}}" oifname "{{UPSTREAM_IFACE}}" accept
        # Traffic steered into a WireGuard tunnel.
        iifname "{{AP_IFACE}}" oifname "wg*" accept
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        oifname "{{UPSTREAM_IFACE}}" masquerade
        oifname "wg*" masquerade
    }
}
